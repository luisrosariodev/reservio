# Django (production)
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=secret-key-for-production-change-me
DJANGO_ALLOWED_HOSTS=app.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://app.example.com

# Security
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
DB_CONN_MAX_AGE=60
DB_FALLBACK_TO_SQLITE_IF_PG_DRIVER_MISSING=False

# Stripe (live or test, according to environment)
STRIPE_SECRET_KEY=replace-with-real-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=replace-with-real-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=replace-with-real-stripe-webhook-secret

# Email provider
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=Reservio <no-reply@example.com>
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=replace-with-provider-api-key
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=10
APP_BASE_URL=https://app.example.com
EMAIL_BRAND_NAME=Reserv.io
EMAIL_BRAND_URL=https://app.example.com
EMAIL_LOGO_URL=/static/img/favicon-256.png
EMAIL_LOGO_FILE=media/favicon-256.png
EMAIL_SUPPORT_EMAIL=support@example.com
EMAIL_FOOTER_NOTE=Este correo fue generado automáticamente por Reserv.io.
EMAIL_LEGAL_NAME=Reserv.io LLC
EMAIL_LEGAL_ADDRESS=San Juan, Puerto Rico
SITE_FAVICON_URL=/static/img/favicon-256.png

# Platform config
PLATFORM_FEE_PERCENT=0
TRAINER_REQUIRE_EMAIL_VERIFICATION=True
TRAINER_SEND_TRANSACTIONAL_EMAILS=True

# Auth/2FA rate limits
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
AUTH_RATE_LIMIT_MAX_ATTEMPTS=8
TWO_FA_RATE_LIMIT_WINDOW_SECONDS=300
TWO_FA_RATE_LIMIT_MAX_ATTEMPTS=8
TWO_FA_METHOD=email
TWO_FA_EMAIL_CODE_TTL_SECONDS=600
TWO_FA_EMAIL_RESEND_COOLDOWN_SECONDS=45
