# Django (development)
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=secret-key-for-dev-only-change-me
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Local DB (leave empty to use sqlite db.sqlite3)
DATABASE_URL=
DB_FALLBACK_TO_SQLITE_IF_PG_DRIVER_MISSING=True

# Stripe (test mode)
STRIPE_SECRET_KEY=replace-with-real-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=replace-with-real-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=replace-with-real-stripe-webhook-secret

# Email (console backend in dev)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=Reservio <no-reply@reservio.local>
EMAIL_TIMEOUT=10
RESEND_API_KEY=
APP_BASE_URL=http://127.0.0.1:8000
EMAIL_BRAND_NAME=Reserv.io
EMAIL_BRAND_URL=http://127.0.0.1:8000
EMAIL_LOGO_URL=
EMAIL_LOGO_FILE=media/favicon-256.png
EMAIL_SUPPORT_EMAIL=support@reservio.local
EMAIL_FOOTER_NOTE=Este correo fue generado automáticamente por Reserv.io.
EMAIL_LEGAL_NAME=Reserv.io Dev
EMAIL_LEGAL_ADDRESS=Entorno local
SITE_FAVICON_URL=/static/img/favicon-256.png

# Feature flags
TRAINER_REQUIRE_EMAIL_VERIFICATION=True
TRAINER_SEND_TRANSACTIONAL_EMAILS=True

# Platform
PLATFORM_FEE_PERCENT=0

# Auth/2FA rate limits
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
AUTH_RATE_LIMIT_MAX_ATTEMPTS=8
TWO_FA_RATE_LIMIT_WINDOW_SECONDS=300
TWO_FA_RATE_LIMIT_MAX_ATTEMPTS=8
TWO_FA_METHOD=email
TWO_FA_EMAIL_CODE_TTL_SECONDS=600
TWO_FA_EMAIL_RESEND_COOLDOWN_SECONDS=45
